annotateRun() {
    controlstring="1kg"
    if [[ $run1kg -eq 0 ]]
    then
        controlstring="customControl"
    fi

    if [[ ${ANALYSISREGION} != "All" ]]
    then
        clipRegion ${CTRL_MERGED} $temp.clippedControl.vcf.gz
        CTRL_MERGED=$temp.clippedControl.vcf.gz
    fi
    
    for query in ${INPUT_VCFS[@]}
    do
        echo "Beginning NeedLR annotation of $query"


        FNAME=$(basename "$query" .vcf.gz)_needLR_${controlstring}_v4.0
        QUERY_ID=$(basename "$query" .vcf.gz)
        ##This is the output directory specific to each query VCF
        UNSOLVED_DIR="$OUTPUTDIR/$FNAME"
        mkdir -p "${UNSOLVED_DIR}"
        output="${UNSOLVED_DIR}/$(basename ${query} .vcf.gz).needLR.$version.intermediate"
        finalOutput="${UNSOLVED_DIR}/$(basename ${query} .vcf.gz).needLR.$version"
        
        if [[ ${ANALYSISREGION} != "All" ]]
        then
            clipRegion ${query} $temp.${query##*/}
            analysisquery=$temp.${query##*/}
        else
            analysisquery=$query
        fi

        if [ ! -z ${COHORT_VCF+x} ]
        then
            echo "Annotating as a cohort"
            cohortControlOverlap ${analysisquery} ${output}
            n="${#COHORT_SAMPLE_NAME_LIST[@]}"
            keepcol=0
        else
            echo "Annotating as a single sample"
            singleVCFControlOverlap ${analysisquery} ${output}
            n=1
            keepcol=1
        fi

        annotateGenes "${output}_summarized.txt" ${output}
        
        geneField=$(head -n1 ${output}_genes.txt| awk '{print NF}')
        let indexField=$geneField-1

        geneIndexedAnnotations ${output}_genes.txt ${output} $geneField $indexField

        positionIndexedAnnotations ${output}_filled.txt ${output}

        printTable ${output}_posannotations.txt ${output} ${finalOutput} "$n"
        printVCF $analysisquery ${finalOutput}_RESULTS.tsv ${output} ${finalOutput} "$n"

        filterTable ${finalOutput}_RESULTS.tsv ${finalOutput}

        echo "Completed NeedLR annotation of ${query}"
        echo "Cleaning up"
        rm ${output}*

        echo -e """\nFiles saved to: \n$(ls $finalOutput*)
        """
    done
}

comparatorRun() {

    controlstring="1kg"
    if [[ $run1kg -eq 0 ]]
    then
        controlstring="customControl"
    fi

    ctype=DUO
    #additional subcommand specific validation
    if [ -z ${PARENTALVCFS+x} ]
    then
        echo "At least one parental vcf is required"
        echo ""
        comparatorHelp
        exit 1
    fi
    PARENTALVCFLIST=( $(echo ${PARENTALVCFS} | tr ',' ' ') )
    if [ "${#PARENTALVCFLIST[@]}" -gt 1 ]
    then
        ctype=TRIO
    fi
    echo ${PARENTALVCFLIST[@]}
    validatedParentalVcfs=()
    for vcf in ${PARENTALVCFLIST[@]}
    do
        validatedParentalVcfs+=( $(validateVCF $vcf ) )
    done

    echo """        Parental VCFs :   ${validatedParentalVcfs[@]}"""
    echo """        Comparator Run :  $ctype"""
    echo ""

    if [[ ${ANALYSISREGION} != "All" ]]
    then
        clipRegion ${CTRL_MERGED} $temp.clippedControl.vcf.gz
        CTRL_MERGED=$temp.clippedControl.vcf.gz
    fi

    query=${INPUT_VCFS[0]} # query is proband input
    echo "Beginning $ctype NeedLR annotation of $query"
    FNAME=$(basename "$query" .vcf.gz)_needLR_${ctype}_${controlstring}_v4.0
    QUERY_ID=$(basename "$query" .vcf.gz)
    ##This is the output directory specific to each query VCF
    UNSOLVED_DIR="$OUTPUTDIR/$FNAME"
    mkdir -p "${UNSOLVED_DIR}"
    output="${UNSOLVED_DIR}/$(basename ${query} .vcf.gz).needLR.$version.intermediate"
    finalOutput="${UNSOLVED_DIR}/$(basename ${query} .vcf.gz).needLR.$version"
    
    if [[ ${ANALYSISREGION} != "All" ]]
    then
        allfiles=( ${query} ${validatedParentalVcfs[@]})
        for infile in ${allfiles[@]}
        do
            clipRegion ${infile} $temp.${infile##*/}
        done
        analysisquery=$temp.${query##*/}
        analysisParentalVcfs=( $temp.${validatedParentalVcfs[0]##*/} )
        if [[ ${#validatedParentalVcfs[@]} -gt 1 ]]
        then
            analysisParentalVcfs+=( $temp.${validatedParentalVcfs[1]##*/} )
        fi

    else
        analysisquery=$query
        analysisParentalVcfs=( ${validatedParentalVcfs[@]} )
    fi

    bcftools reheader -n Proband -o ${output}_proband.vcf.gz $analysisquery
    tabix -p vcf ${output}_proband.vcf.gz

    #if this is a duo we want to keep two genotypes
    if [[ $ctype == "TRIO" ]]
    then
        COHORT_SAMPLE_NAME_LIST=(Proband Maternal Paternal )
        bcftools reheader -n Maternal -o ${output}_maternal.vcf.gz ${analysisParentalVcfs[0]}
        tabix -p vcf ${output}_maternal.vcf.gz
        bcftools reheader -n Paternal -o ${output}_paternal.vcf.gz ${analysisParentalVcfs[1]}
        tabix -p vcf ${output}_paternal.vcf.gz

        parentString=${output}_maternal.vcf.gz,${output}_paternal.vcf.gz
        n=3
    else
        COHORT_SAMPLE_NAME_LIST=(Proband Parental )
        bcftools reheader -n Parental -o ${output}_parental.vcf.gz ${analysisParentalVcfs[0]}
        tabix -p vcf ${output}_parental.vcf.gz

        parentString=${output}_parental.vcf.gz
        n=2
    fi

    echo "Annotating as a $ctype"

    multiVCFControlOverlap ${output}_proband.vcf.gz,${parentString} ${output} ${n}

    annotateGenes "${output}_inheritance.txt" ${output}
    
    geneField=$(head -n1 ${output}_genes.txt| awk '{print NF}')
    let indexField=$geneField-1

    geneIndexedAnnotations ${output}_genes.txt ${output} $geneField $indexField

    positionIndexedAnnotations ${output}_filled.txt ${output}

    ## add back in the proband read depths and totals + parental genotypes
    ## remove records with no proband gt
    paste <( cut -f1-9 ${output}_posannotations.txt) \
        ${output}_dvdr.txt \
        <(cut -f17- ${output}_posannotations.txt) \
        | grep -v "not_present" > ${output}_fullwidth.txt

    printTable ${output}_fullwidth.txt ${output} ${finalOutput} $n
    printVCF $analysisquery ${finalOutput}_RESULTS.tsv ${output} ${finalOutput} $n

    

    filterInheritance ${finalOutput}_RESULTS.tsv ${finalOutput} $ctype

    echo "Completed NeedLR annotation of ${query}"
    echo "Cleaning up"
    rm ${output}*

    echo -e """\nFiles saved to: \n$(ls $finalOutput*)
    """
}

bedRun() {
    #additional subcommand specific validation
    if [ ${#INPUT_BEDS[@]} -lt 1 ]
    then
        echo "needLR bed requires bed file input"
        echo ""
        bedHelp
        exit 1
    fi
    for query in ${INPUT_BEDS[@]}
    do
        echo "Beginning NeedLR bed annotation of $query"
        FNAME=$(basename "$query" .bed)_needLR_bed_v4.0
        QUERY_ID=$(basename "$query" .bed)
        ##This is the output directory specific to each query VCF
        UNSOLVED_DIR="$OUTPUTDIR/$FNAME"
        mkdir -p "${UNSOLVED_DIR}"
        output="${UNSOLVED_DIR}/$(basename ${query} .bed).needLR.$version.intermediate"
        finalOutput="${UNSOLVED_DIR}/$(basename ${query} .bed).needLR.$version"

        if [[ ${ANALYSISREGION} != "All" ]]
        then
            clipRegion ${query} $temp.${query##*/}
            analysisquery=$temp.${query##*/}
        else
            analysisquery=$query
        fi

        ncols=$( head -n1 $analysisquery | awk '{print NF}')
        bedheader=( $(head -n1 $analysisquery) )
        if [[ ${bedheader[0]} =~ '#' ]]
        then
            cat $analysisquery | \
                awk 'NR>1{diff=$3-$2;if(diff> -10000000 && diff < 10000000){print $0}}' > ${output}_temp1.txt
            hasheader=1
        else
            cat $analysisquery | \
                awk '{diff=$3-$2;if(diff> -10000000 && diff < 10000000){print $0}}' > ${output}_temp1.txt
            hasheader=0
        fi

        annotateGenes "${output}_temp1.txt" ${output}
        
        geneField=$(head -n1 ${output}_genes.txt| awk '{print NF}')
        let indexField=$geneField-1

        geneIndexedAnnotations ${output}_genes.txt ${output} $geneField $indexField

        positionIndexedAnnotations ${output}_filled.txt ${output}

        if [[ $hasheader -eq 0 ]]
        then
            header=( '#CHROM' START END )
            for((i=3;i<$ncols;i++))
            do
                header+=( "column"$i )
            done
        else
            header=( ${bedheader[@]} )
        fi

        annocols=( $(printAnnotationHeader) )
        header+=( Genes ${annocols[@]:1} )

        echo ${header[@]} | tr ' ' '\t' > ${finalOutput}.bed

        cat ${output}_posannotations.txt >> ${finalOutput}.bed
        echo "Cleaning up"
        rm ${output}*

        echo -e """\nFiles saved to: \n$(ls $finalOutput*)
        """
        
    done
}

