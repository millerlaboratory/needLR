printTable() {
    local input=$1
    local output=$2
    local finalOutput=$3
    local nquery=$4

    echo "Printing tabular results to ${finalOutput}_RESULTS.tsv"

    # make different headers depending on input options
    tableheader=( CHROM POS End_Pos REF ALT SVLEN SVTYPE )
    case $nquery in
        1) tableheader+=( Control_support Genotype Alt_Reads Ref_Reads Total_Reads ) ;;
        2) tableheader+=( Inheritance Control_support Genotype Alt_Reads Ref_Reads Total_Reads Parental_GT Parental_Alt_Reads Parental_Ref_Reads Parental_Total_Reads) ;;
        3) tableheader+=( Inheritance Control_support Genotype Alt_Reads Ref_Reads Total_Reads Maternal_GT Maternal_Alt_Reads Maternal_Ref_Reads Maternal_Total_Reads Paternal_GT Paternal_Alt_Reads Paternal_Ref_Reads Paternal_Total_Reads ) ;;
        *) tableheader+=( Cohort_support Control_support Pop_Count_Cohort Pop_Freq_Cohort Allele_Count_Cohort Allele_Freq_Cohort GT_coh_homWT GT_coh_het GT_coh_homVAR )
    esac

    sampleend=${#tableheader[@]}
    
    
    annotationcols=1
    tableheader+=( Allele_Freq_ALL_Control Genes )
    annocols=( $(printAnnotationHeader) )
    let annotationcols+=${annocols[0]}
    tableheader+=( ${annocols[@]:1} )

    let controlstart=$sampleend+1
    let controlend=controlstart
    if [[ $run1kg -eq 1 ]] #this should be replaced with optional subpopulation names in a later release
    then
        tableheader+=(  Pop_Count_AFR Pop_Freq_AFR
                        Pop_Count_AMR Pop_Freq_AMR 
                        Pop_Count_EAS Pop_Freq_EAS
                        Pop_Count_EUR Pop_Freq_EUR
                        Pop_Count_SAS Pop_Freq_SAS
                        Pop_Count_ALL Pop_Freq_ALL 
                        Allele_Count_AFR Allele_Freq_AFR
                        Allele_Count_AMR Allele_Freq_AMR 
                        Allele_Count_EAS Allele_Freq_EAS
                        Allele_Count_EUR Allele_Freq_EUR
                        Allele_Count_SAS Allele_Freq_SAS
                        Allele_Count_ALL Allele_Freq_ALL )
        let controlend=$controlstart+24-1
        afcol=$controlend
    else
        tableheader+=( Pop_Count_ALL Pop_Freq_ALL Allele_Count_ALL Allele_Freq_ALL )
        let controlend=$controlstart+3
        afcol=$controlend
    fi

    tableheader+=( GT_homWT GT_het GT_homVAR p q HWE  )
    let gtstart=$controlend-1
    let gtstop=$controlend+6

    let annostart=$gtstop+1

    if [[ ! -z ${COHORT_VCF+x} ]]
    then
        paste <(cat $input | cut -f 1-$sampleend,$afcol,${annostart}- ) \
            <(cat $input | cut -f $controlstart-${gtstop} ) > ${output}_results_long.txt
    else
        paste <(cat $input | cut -f 1-$sampleend,$afcol,${annostart}- ) \
            <(cat $input | cut -f $controlstart-${gtstop} ) > ${output}_results_long.txt
    fi

    ## truncate oversized fields, write header, filter result files

    longcols=( 4 5 ) #REF ALT
    let annotationstart=$sampleend+2
    NF=$( head -n1 ${output}_results_long.txt | awk '{print NF}' )
    let SUBGROUPCOLUMNS=${NSUBGROUPS}*4
    let annotationstop=$NF-6-$SUBGROUPCOLUMNS
    
    echo "${tableheader[@]}" | tr ' ' '\t' > ${finalOutput}_RESULTS.tsv
        
    cat ${output}_results_long.txt | \
        awk -F '\t' -v annostart=${annotationstart} -v annostop=${annotationstop} \
        -v ref=4 -v alt=5 'BEGIN{OFS="\t"}\
        {if(length($ref) > 30000){$ref="[too_long_see_vcf]"};
            if(length($alt) > 30000){$alt="[too_long_see_vcf]"};
            for(i=annostart;i<=annostop;i++){
                if(length($i) > 30000){$i="[too_long_see_vcf]"}};
            print $0}' >> ${finalOutput}_RESULTS.tsv
    
    #This removes "?s" from OMIM annotations (hard to sort)
    sed -i 's/?//g' ${finalOutput}_RESULTS.tsv
    #This removes empty lines from the bottom of the txt file
    sed -i -e :a -e '/^[[:space:]]*$/{$d;N;ba}' ${finalOutput}_RESULTS.tsv
}

filterTable() {
    local input=$1
    local output=$2

    if [ -z ${COHORT_VCF+x} ] #if running with a cohort, account for different # cols
    then
        afcol=13
    else
        afcol=17
    fi

    ##Filtered output 1: SVs absent from 1KGP entirely (afcol = Allele_Freq_ALL_1KGP)
    awk -F'\t' -v afcol=$afcol 'BEGIN{OFS="\t"} NR==1 || $afcol==0 {print}' \
     $input > "${output}_RESULTS_unique.tsv"

    ##Filtered output 2: SVs with 1KGP allele freq <=0.01
    awk -F'\t' -v afcol=$afcol 'BEGIN{OFS="\t"} NR==1 || $afcol<=0.01 {print}' \
     $input > "${output}_RESULTS_0.01.tsv"
}

filterInheritance() {
    local input=$1
    local output=$2
    local runtype=$3

    if [[ $runtype == "TRIO" ]]
    then    
        afcol=22
        incol=8

        ##Filtered output 3: de novo SVs
        awk -F'\t' -v inheritance=$incol 'BEGIN{OFS="\t"} NR==1 || $inheritance=="de_novo" {print}' \
        $input > "${output}_RESULTS_denovo.tsv"

    else
        afcol=18
        incol=8

        awk -F'\t' -v inheritance=$incol 'BEGIN{OFS="\t"} NR==1 || $inheritance=="not_inherited" {print}' \
        $input > "${output}_RESULTS_not_inherited.tsv"
    fi

    ##Filtered output 1: SVs absent from 1KGP entirely (afcol = Allele_Freq_ALL_1KGP)
    awk -F'\t' -v afcol=$afcol 'BEGIN{OFS="\t"} NR==1 || $afcol==0 {print}' \
     $input > "${output}_RESULTS_unique.tsv"

    ##Filtered output 2: SVs with 1KGP allele freq <=0.01
    awk -F'\t' -v afcol=$afcol 'BEGIN{OFS="\t"} NR==1 || $afcol<=0.01 {print}' \
     $input > "${output}_RESULTS_0.01.tsv"

     
}

clipRegion() {
    local input=$1
    local output=$2

    inputext=${input##*.}

    if [[ $inputext != "gz" ]]
    then
        if [[ $inputext == "bed" || $inputext == "vcf" ]]
        then
            filename=${input##*/}
            cp $input $temp.${filename}
            bgzip $temp.${filename}
            tabix -p $inputext $temp.${filename}.gz
            cleaninput=$temp.${filename}.gz
            filetype=$inputext
        else
            echo "file input type $inputext can't be used with needLR"
            exit 1
        fi
    else
        cleaninput=$input
        originalfile=${input%*.gz}
        filetype=${originalfile##*.}
        if [[ $filetype != "bed" && $filetype != "vcf" ]]
        then
            echo "file input type $inputext can't be used with needLR"
            exit 1
        fi
    fi

    if [[ ${output##*.} != "gz" ]]
    then
        cleanoutput=$output.gz
    else
        cleanoutput=$output
    fi

    tabix -h $cleaninput ${ANALYSISREGION} > ${cleanoutput%*.gz}
    if [[ $filetype == "vcf" ]]
    then
        bgzip ${cleanoutput%*.gz}
        tabix -p $filetype ${cleanoutput}
    fi

}


