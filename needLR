truvari_merge () {
    local query_files=$1
    local output=$2

    query_list=( $(echo ${query_files} | tr ',' ' ') )

    echo -e "\nStarting Step 1 (prep and merge)\n"
    #output="${UNSOLVED_DIR}/$(basename ${query_file} .vcf.gz).intermediate"

    #This preprocesses the query VCFs to be >=50bp, on full chromosomes, and FILTER=PASS
    echo "Preprocessing query VCF to SVs >=50bp, on full chromosomes, FILTER=$FILTERPASS"
    #bcffilters=\''(INFO/SVTYPE="BND") || (INFO/SVTYPE="INS" || INFO/SVTYPE="DEL" || INFO/SVTYPE="DUP" || INFO/SVTYPE="INV") && (INFO/SVLEN > 49 || INFO/SVLEN < -49) && GT!="0/0" && GT!="0|0"'\'
    chroms="chr1,chr2,chr3,chr4,chr5,chr6,chr7,chr8,chr9,chr10,chr11,chr12,chr13,chr14,chr15,chr16,chr17,chr18,chr19,chr20,chr21,chr22,chrX,chrY,chrM"

    if [ -f "${temp}.list_temp.txt" ]
    then
        rm "${temp}.list_temp.txt"
    fi
    for((i=0;i<${#query_list[@]};i++))
    do
        query_file=${query_list[$i]}
        currentlines=$( zgrep -v ^# ${query_file} | wc -l | tr -s ' ' | cut -f1 -d ' ')
        echo "There are $currentlines starting variants in ${query_file}"

        
        if [ $FILTERPASS -eq 1 ]
        then
            bcftools view -f PASS \
            -i '(INFO/SVTYPE="BND") || (INFO/SVTYPE="INS" || INFO/SVTYPE="DEL" || INFO/SVTYPE="DUP" || INFO/SVTYPE="INV") && (INFO/SVLEN > 49 || INFO/SVLEN < -49) && GT!="0/0" && GT!="0|0"' \
                -r $chroms \
                -o ${output}.${i}.filter.vcf.gz \
                --threads ${THREADS} \
                --write-index=tbi "${query_file}"
        else
            bcftools view -i '(INFO/SVTYPE="BND") || (INFO/SVTYPE="INS" || INFO/SVTYPE="DEL" || INFO/SVTYPE="DUP" || INFO/SVTYPE="INV") && (INFO/SVLEN > 49 || INFO/SVLEN < -49) && GT!="0/0" && GT!="0|0"' \
                -r $chroms \
                -o ${output}.${i}.filter.vcf.gz \
                --threads ${THREADS} \
                --write-index=tbi "${query_file}"
        fi

        newlines=$( zgrep -v ^# ${output}.${i}.filter.vcf.gz | wc -l | tr -s ' ' | cut -f1 -d ' ')
        delta=$(( currentlines-newlines ))
        echo "Removed $delta lines from ${query_file}"
        currentlines=$newlines

        echo "${output}.${i}.filter.vcf.gz" >> "${temp}.list_temp.txt" #actually adding to the list inside of the loop
    done

    #This creates the input list of VCFs for bcftools merge
    echo "Creating list of input VCFs for bcftools merge"
    echo "${CTRL_MERGED}" >> "${temp}.list_temp.txt"

    #bcftools merge
    echo "Merging"
    bcftools merge -m none \
        --force-samples \
        -l "${temp}.list_temp.txt" \
        -Oz \
        --threads $THREADS \
        -o "${output}_bcftools_merged_with_ctrl_temp.vcf.gz" \
        --write-index=tbi

    newlines=$( zgrep -v ^# ${output}_bcftools_merged_with_ctrl_temp.vcf.gz | wc -l | tr -s ' ' | cut -f1 -d ' ')
    delta=$(( currentlines-newlines ))
    echo "Added $delta lines"
    currentlines=$newlines

    #Truvari collapse (T31)
    echo "Running truvari collapse"
    truvari collapse -i "${output}_bcftools_merged_with_ctrl_temp.vcf.gz" \
        -o "${output}_truvari_merged_temp.vcf" \
        -c "${output}_truvari_collapsed_temp.vcf" \
        -k "${truvari_k}" \
        -s "${truvari_s}" \
        -S "${truvari_S}" \
        -r "${truvari_r}" \
        -p "${truvari_p}" \
        -P "${truvari_P}" \
        -O "${truvari_O}"

    ##This parses the Truvari VCF output for relevant information
    echo "Parsing Truvari VCF output"
    bcftools query -f '%CHROM\t%POS\t%REF\t%ALT\t%INFO/SVLEN\t%INFO/SVTYPE[\t%GT\t%DV\t%DR]\n' \
        "${output}_truvari_merged_temp.vcf" > "${output}_truvari_merged_temp.txt"

    newlines=$( wc -l ${output}_truvari_merged_temp.txt | tr -s ' ' | cut -f1 -d ' ')
    echo "Truvari output has $newlines lines"

    echo -e "\nDone with Step 1\n"
}

parse_vcf() {
    local input=$1
    local output=$2
    local nquery=$3

    echo -e "Starting Step 2 (filter vcf)\n"

    currentlines=$( wc -l $input | tr -s ' ' | cut -f1 -d ' ')
    echo "There are $currentlines starting variants"

    echo "Filtering reference only calls"
    if [[ $nquery -gt 1 ]]
    then
        QUERY_LAST_GT=$(( 7 + ($nquery)*3 ))

        cat $input | awk -v first=7 \
        -v last="${QUERY_LAST_GT}" \
        -v step=3 'BEGIN {OFS="\t"}{
        for (i = first; i <= last; i += step) {
            if ($i != "./.") { print; next }
            }
        }' > "${output}_truvari_merged_query_filtered_temp.txt"
    else
        QUERY_GT=7
        cat $input | awk -v qcol=${QUERY_GT} \
        'BEGIN{OFS="\t"}{if($qcol!="./."){print $0}}' > "${output}_truvari_merged_query_filtered_temp.txt"
    fi
    newlines=$( wc -l "${output}_truvari_merged_query_filtered_temp.txt" | tr -s ' ' | cut -f1 -d ' ')
    delta=$(( currentlines-newlines ))
    echo "Removed $delta lines"
    currentlines=$newlines

    ##This removes BNDs from the analysis (too large to efficiently annotate)
    echo "Filtering BNDs"
    cat "${output}_truvari_merged_query_filtered_temp.txt" | grep -v BND > "${output}_temp1.txt"
    
    newlines=$( wc -l "${output}_temp1.txt" | tr -s ' ' | cut -f1 -d ' ')
    ldelta=$(( currentlines-newlines ))
    echo "Removed $delta lines"
    currentlines=$newlines

    ##This parses for SVs <=10Mb
    echo "Parsing for SVs <= 10Mb"
    cat "${output}_temp1.txt" | awk '{if($5 > -10000000 && $5 < 10000000){print $0}}' > \
        "${output}_temp2.txt"

    newlines=$( wc -l "${output}_temp2.txt" | tr -s ' ' | cut -f1 -d ' ' )
    delta=$(( currentlines-newlines ))

    echo "Removed $delta lines"
    currentlines=$newlines

    echo "There are $currentlines variants"

    # final output for this function is "${output}_temp2.txt"
    echo -e "\nDone with Step 2\n"
}    

collapse_gt() {
    local input=$1
    local output=$2
    local nquery=$3
    local keepDVDR=$4

    ##   Collapse to GT-only columns (drop DV/DR)
    ##   input layout (1-indexed):
    ##   $1-$6                  : CHROM POS REF ALT SVLEN SVTYPE
    ##   $7 .. $6+COHORT        : cohort GTs (one col per sample)
    ##   $7+COHORT .. $6+COHORT+CTRL : 1KGP GTs (one col per sample)
    ## this step also adds a '.' in position 3 to later hold the SV end pos
    echo -e "\nStarting Step 3 (preprocess gt columns)\n"

    STEP=3
    if [[ "${keepDVDR}" -eq 1 ]]
    then
        echo "keeping dv/dr"
        cat "${input}" | \
        $scriptpath/src/./rearrange.awk \
         --assign step=$STEP \
         --assign ncohort=$nquery \
         --assign ncontrols="${TOTAL_SAMPLES}" \
         | tr -s '\t' > "${output}_temp3.txt"
    else
        echo "keeping only gt columns"
        QUERY_END=$(( 7 + (nquery-1)  * 3 ))
        cat "${input}" | \
        $scriptpath/src/./rearrange_dropdvdr.awk \
         --assign step="${STEP}" \
         --assign ncohort=$nquery \
         --assign ncontrols="${TOTAL_SAMPLES}" \
         | tr -s '\t' > "${output}_temp3.txt"
    fi
    # final output for this function is "${output}_temp3.txt"
    echo -e "\nDone with Step 3\n"
}

make_supp_vecc() {
    local input=$1
    local output=$2
    local nquery=$3
    local keepDVDR=$4

    echo -e "\nStarting Step 4 (making support vector)\n"

    if [[ "${keepDVDR}" -eq 1 ]]
    then
        querycols=4
        echo "not dropping any query columns"
    else
        querycols=1
        echo "dropping query DV/DR columns"
    fi
    ##This creates a SUPP_VEC (like in Jasmine)
    Q_GT_START=8
    Q_GT_END=$(( 7 + (nquery*querycols) )) #preserving the closed interval
    Q_GT_STEP="${querycols}"
    CONTROL_GT_START=$(( Q_GT_END + 1 ))
    CONTROL_GT_END=$(( CONTROL_GT_START + TOTAL_SAMPLES - 1 )) #preserving the closed interval
    

    #If there is more than one sample, make a supp vecc for the cohort
    if [[ "${nquery}" -gt 1 ]]
    then
        echo "creating support vector for query cohort"
        cat "${input}" | $scriptpath/src/./supvec.awk \
            --assign start="${Q_GT_START}" \
            --assign end="${Q_GT_END}" \
            --assign step="${Q_GT_STEP}" | 
            awk 'BEGIN{OFS="\t"}{printf("%s\t\n", $0)}'> "${output}_temp4.1.txt"
    else
        cat "${input}" > "${output}_temp4.1.txt"
    fi

    # Always make one for controls
    echo "creating support vector for controls"
    cat "${output}_temp4.1.txt" | $scriptpath/src/./supvec.awk \
        --assign start="${CONTROL_GT_START}" \
        --assign end="${CONTROL_GT_END}" \
        --assign step=1 > "${output}_temp4.txt"

    ##Rearrange columns so SUPP_VECs are columns 8/9
    endcol=$( head -n1 ${output}_temp4.txt | awk '{print NF}' )
    let endcol=$endcol-1
    SUPP_VEC=$( cat "${output}_temp4.txt" | awk 'NR==1{print NF}' )
    if [[ "${nquery}" -gt 1 ]]
    then
        let SUPP_VEC="${SUPP_VEC}"-1
        let endcol=$endcol-1
    fi

    #SUPP_VEC=$(( CONTROL_GT_END + 1 )) # the position of the first support vector

    echo "Moving support vector(s)"
    paste <( cut -f 1-7 "${output}_temp4.txt" ) \
        <( cut -f "${SUPP_VEC}-" "${output}_temp4.txt" ) \
        <( cut -f "8-${endcol}" "${output}_temp4.txt" ) > "${output}_temp5.txt"


    ## Calculate population stratified frequency statistics
    ## this version of the awk script can accept any breaks, not implemented yet for anything but 1kg
    if [[ $run1kg -eq 1 ]]
    then
        breaks="$AFR,$AMR,$EAS,$EUR,$SAS"
        echo "using subpopulation breaks: $breaks"
    else
        breaks="${TOTAL_SAMPLES}"
        echo "no subpopulation breaks provided"
    fi

    echo "calculating population stratified frequency statistics"
    cat "${output}_temp5.txt" | $scriptpath/src/./annocustomcontrol.awk \
        --assign controlbreaks=$breaks \
        --assign ncohort=$nquery \
        --assign ncontrols="${TOTAL_SAMPLES}" \
        --assign step=$querycols > "${output}_temp6.txt"


    ##This matches the SUPP_VEC string(s) to the sample list (and lists which 1KGP samples have the SV)
    
    names=$(echo "${CTRL_SAMPLE_NAME_LIST[@]}" | tr ' ' ',')
    if [[ $nquery -gt 1 ]]
    then
        echo "Matching vector support with cohort sample names"
        cohortnames=$(echo "${COHORT_SAMPLE_NAME_LIST[@]}" | tr ' ' ',')
        cat "${output}_temp6.txt" | \
            $scriptpath/src/./matchSuppVecc.awk \
            --assign names=$cohortnames \
            --assign colindex=8 > "${output}_temp6.1.txt"
        echo "Matching vector support with control sample names"
        cat "${output}_temp6.1.txt" | \
            $scriptpath/src/./matchSuppVecc.awk \
            --assign names=$names \
            --assign colindex=9 > "${output}_temp7.txt"
    else
        echo "Matching vector support with control sample names"
        cat "${output}_temp6.txt" | \
            $scriptpath/src/./matchSuppVecc.awk \
            --assign names=$names \
            --assign colindex=8 > "${output}_temp7.txt"
    fi
    # final output for this function is ${output}_temp7.txt
    echo -e "\nDone with Step 4\n"
}

hwe() {
    local input=$1
    local output=$2
    local nquery=$3
    local keepDVDR=$4

    echo -e "\nStarting Step 5 (HWE)\n"
    if [[ "${keepDVDR}" -eq 1 ]]
    then
        querycols=4
    else
        querycols=1
    fi

    ## This calculates p for HWE - WT alle freq ((2*homWT) + het)/(2* (homWT + het + homVar))
    ## Checks for demoninator of zero (if SV is counted but genotype is ./. for a control sample)
    ## This calculates q for HWE - (1-p)
    ## This calculates np^2, 2npq, and nq^2 for HWE
    ## This calculates chi-squared value for HWE. (Can't divide by zero, so if expected is zero, chi-sq=NULL) 
    ## For efficiency what was previously seaprated into the steps above was combined into one awk script. 
    ## file output names preserved for readability
    echo "calculating HWE statistics"
    cat "${output}_temp7.txt" | \
        $scriptpath/src/./hwe.awk \
        --assign totsamples="${TOTAL_SAMPLES}" > "${output}_temp11.txt"

    #This lists all population counts/frequencies, allele counts/frequencies, and HWE info
    echo "Tabulating subpopulation and population count/frequencies"
    if [[ "${run1kg}" -eq 1 ]]
    then
        subpopcounts="${AFR},${AMR},${EAS},${EUR},${SAS}"
    else
        subpopcounts="${TOTAL_SAMPLES}"
    fi
    cat "${output}_temp11.txt" | \
        $scriptpath/src/./assign_counts.awk \
        --assign ncontrols="${TOTAL_SAMPLES}" \
        --assign ncohort="$nquery" \
        --assign step=$querycols \
        --assign controlcounts="${subpopcounts}" > "${output}_temp12.txt"

    echo "Assigning HWE equilibrium"
    #This determines if the SV is in HWE
    hwecol=$( awk 'NR==1{print NF-3}' "${output}_temp12.txt" )

    cat "${output}_temp12.txt" | \
        $scriptpath/src/./hwe_check.awk | \
        cut -f 1-"${hwecol}" > "${output}_temp13.txt"

    echo "Assigning SV end position"
    ##This adds the absolute value of the length of the SV to the start position (DELs are listed as negative lengths in the vcf, but the range is from the start position plus that number of nucleotides)
    cat "${output}_temp13.txt" | \
        $scriptpath/src/./svlen.awk > "${output}_control_overlap.txt"

    # final output for this funciton is ${output}_control_overlap.txt
    echo -e "\nDone with Step 5\n"
}

condenseSummary() {
    # this makes the summary for the cohort and drops GT control columns
    local input=$1
    local output=$2
    local nquery=$3
    local keepDVDR=$4

    echo -e "\nStarting Step 6 (summarizing and cleanup)\n"

    if [[ "${keepDVDR}" -eq 1 ]]
    then
        querycols=4
    else
        querycols=1
    fi

    ngts=${TOTAL_SAMPLES}
    samplecols=4
    if [[ $nquery -gt 1 ]]
    then
        let ngts+=$nquery
        let samplecols=1
    fi
     #offset for use with cut
    let keepend=8+$samplecols
    let loseend=$keepend+$ngts+1

    paste <(cut -f1-$keepend $input) \
        <(cut -f $loseend- $input) > "${output}_summarized.txt"

    echo -e "\nDone with Step 6\n"
    
}

inheritanceSupVec() {
    # this transforms the cohort support vector into a parental inheritnace column
    # it also notes records that are not present in the proband
    local input=$1
    local output=$2
    local nquery=$3
    local keepDVDR=$4

    # the cohort (parental) support vector will always be field 8
    if [[ $nquery == 3 ]]
    then
        cut -f8 $input | awk -F '_' '{if(NF==1 ){\
            if($0=="Proband"){print "de_novo"}
            else{print "not_present"}
        };\
        if(NF==3){print "inherited"};
        if(NF==2){\
            if($0!~/Proband/){
                print "not_present"}
            else if($0~/Maternal/){\
                print "maternal"}
            else if($0~/Paternal/){\
                print "paternal"}
            else {print "inherited"}}}' > $output.inheritances.txt
    else
        cut -f8 $input | awk -F '_' '{if($0!~/Proband/){print "not_present"}\
        else if(NF==1 && $0=="Proband"){print "not_inherited"}\
        else if(NF==2){print "inherited"}}' > $output.inheritances.txt
    fi

    paste <(cut -f1-7 ${input}) $output.inheritances.txt <(cut -f9- ${input})  > ${output}_inheritance.txt 
}

cohortControlOverlap() {
    local query=$1
    local output=$2

    # get number of samples and sample names from the input
    COHORT_SAMPLE_NAME_LIST=( $(bcftools view -h ${query} | grep -v ^## | cut -f10-) )
    COHORT_SAMPLES=${#COHORT_SAMPLE_NAME_LIST[@]}

    truvari_merge "${query}" "${output}"
    parse_vcf "${output}_truvari_merged_temp.txt" "${output}" "${COHORT_SAMPLES}"
    collapse_gt "${output}_temp2.txt" "${output}" "${COHORT_SAMPLES}" 0
    make_supp_vecc "${output}_temp3.txt" "${output}" "${COHORT_SAMPLES}" 0
    hwe "${output}_temp7.txt" "${output}" "${COHORT_SAMPLES}" 0
    condenseSummary "${output}_control_overlap.txt" "${output}" "${COHORT_SAMPLES}" 0

}


singleVCFControlOverlap() {
    local query=$1
    local output=$2

    truvari_merge "${query}" "${output}"
    parse_vcf "${output}_truvari_merged_temp.txt" "${output}" 1
    collapse_gt "${output}_temp2.txt" "${output}" 1 1
    make_supp_vecc "${output}_temp3.txt" "${output}" 1 1
    hwe "${output}_temp7.txt" "${output}" 1 1
    condenseSummary "${output}_control_overlap.txt" "${output}" 1 1

}

multiVCFControlOverlap() {
    local queries=$1
    local output=$2
    local n=$3

    truvari_merge "${queries}" "${output}"
    parse_vcf "${output}_truvari_merged_temp.txt" "${output}" ${n}
    collapse_gt "${output}_temp2.txt" "${output}" ${n} 0 #read depth columns are dropped here
    # keep gt,alt depth,ref depth for later
    let ncols=3*n
    let colend=$ncols+6
    let cutcol=4*n

    cut -f7-${colend} ${output}_temp2.txt | awk 'BEGIN{OFS="\t"}\
        {for(i=1;i<=NF;i+=3){\
            totalreads=$(i+1)+$(i+2);\
            if(totalreads==""){totalreads="."}
            printf("%s\t%s\t%s\t%s\t", $i,$(i+1),$(i+2),totalreads)}
        printf "dummy\n"}' | \
        cut -f1-${cutcol} > ${output}_dvdr.txt
    make_supp_vecc "${output}_temp3.txt" "${output}" ${n} 0
    hwe "${output}_temp7.txt" "${output}" ${n} 0
    condenseSummary "${output}_control_overlap.txt" "${output}" ${n} 0
    inheritanceSupVec ${output}_summarized.txt ${output} ${n} 0
}

annotateGenes() {
    #This annotates each variant with gene info (+/-5kb to try to capture promoters, etc)
    local input=$1
    local output=$2

    NF=$(head -n1 $input | awk '{print NF}')
    let geneFieldInitial=$NF+4
    let geneField=$NF+1


    echo -e "\nAnnotating gene overlap\n"

    # remove gene coordinates from output and sort on gene name
    # previously output_temp18.txt
    bedtools intersect -wa -wb -loj \
        -a $input \
        -b $GENES | cut -f1-${NF},${geneFieldInitial} | sort -k${geneField},${geneField} > "${output}_genes.txt"

    echo -e "\nDone\n"
}

geneIndexedAnnotations() {
    local input=$1
    local output=$2
    local geneField=$3
    local indexField=$4

    # apply name indexed annotations
    echo "Assigning name indexed annotations"

    if [[ "${SELECTEDANNO}" =~ "omim" ]]
    then
        #adds two columns
        echo "Applying OMIM annotations"
        bash $scriptpath/src/annotateNamed.sh -i ${input} -o ${output}_omim.txt -a ${OMIM_GENES} -c 1,3 -g $geneField
        input=${output}_omim.txt
    fi
    if [[ "${SELECTEDANNO}" =~ "gencc" ]]
    then
        #adds three columns
        echo "Applying GENCC annotations"
        bash $scriptpath/src/annotateNamed.sh -i ${input} -o ${output}_gencc.txt -a ${GENCC} -g $geneField
        input=${output}_gencc.txt
    fi
    if [[ "${SELECTEDANNO}" =~ "hpo" ]]
    then
        #adds one column
        echo "Applying HPO term annotations"
        bash $scriptpath/src/annotateNamed.sh -i ${input} -o ${output}_hpo.txt -a "${OMIM_GENES}" -c 4 -g $geneField
        input=${output}_hpo.txt
    fi
    if [[ "${SELECTEDANNO}" =~ "pli" ]]
    then
        #adds one column
        echo "Applying gnomAD pLI annotations"
        bash $scriptpath/src/annotateNamed.sh -i ${input} -o ${output}_pli.txt -a ${PLI} -g $geneField
        input=${output}_pli.txt
    fi

    # Consolidate multigene rows
    echo "Consolidating multigene rows"
    cat $input | $scriptpath/src/./consolidateRows.awk \
        --assign indexField=$indexField > ${output}_consolidated.txt
    

    ##Replace empty fields with "."
    awk 'BEGIN {FS = OFS = "\t"} {for (i = 1; i <= NF; i++) if ($i == "") $i = "."} 1' ${output}_consolidated.txt > ${output}_filled.txt

    echo "Name indexed annotations complete"
}

positionIndexedAnnotations() {
    local originalInput=$1
    local output=$2

    echo "Assigning position based annotations"
    bedtools sort -i $originalInput > "${output}"_pos_sorted.txt
    input="${output}"_pos_sorted.txt
    if [[ "${SELECTEDANNO}" =~ utr ]]
    then
        echo "Finding UTR overlap"
        bedtools map \
        -a "$input" \
        -b "$UTR" \
        -c 5 \
        -o distinct \
        > "${output}"_utr.txt
        input=${output}_utr.txt
    fi
    if [[ "${SELECTEDANNO}" =~ cds ]]
    then
        echo "Finding CDS overlap"
        bedtools map \
        -a "${input}" \
        -b "$CDS" \
        -c 6 \
        -o collapse \
        | awk 'BEGIN{FS=OFS="\t"} \
        {$NF= ($NF==-1 || $NF==".") ? "." : "CDS" ; print $0}' > "${output}"_cds.txt
        input=${output}_cds.txt
    fi
    if [[ "${SELECTEDANNO}" =~ oreganno ]]
    then
        echo "Finding OregaNNO overlap"
        bedtools map \
        -a "$input" \
        -b "$OREGANNO" \
        -c 4 \
        -o distinct \
        > "${output}"_oreganno.txt
        input=${output}_oreganno.txt
    fi
    if [[ "${SELECTEDANNO}" =~ tre ]]
    then
        echo "Finding TRE overlap"
        awk 'BEGIN{FS=OFS="\t"} $7!="INS" && $7!="DEL" && $7!="DUP" {print $0, "."}' \
            "${input}" > "${output}"_novamos.txt
        bedtools map \
            -a ${input} \
            -b $VAMOSEXPAND \
            -c 4 \
            -o distinct | \
            awk -F '\t' '{if($7=="DUP" || $7=="INS"){print $0}}' > ${output}_insdup.txt
        bedtools map \
            -a ${input} \
            -b $VAMOS \
            -c 4 \
            -o distinct | \
            awk -F '\t' '{if($7=="DEL"){print $0}}' > ${output}_del.txt
        cat ${output}_insdup.txt ${output}_del.txt ${output}_novamos.txt | \
            awk 'BEGIN{FS=OFS="\t"} {$NF=($NF==-1||$NF==".")?".":"vamos"; print}' \
            | sort -k1,1 -k2,2n -k3,3n | uniq > ${output}_tre.txt
        input=${output}_tre.txt
    fi
    if [[ "${SELECTEDANNO}" =~ mapflags ]] #includes centromeres, pericentromeres, telomeres, segdups, repeats, gaps, homopolymers
    then
        # centromeres, pericentromeres, telomeres
        echo "Finding centromeres, pericentromere, telomere overlap"
        NF=$( head -n1 ${input} | awk -F '\t' '{print NF}')
        let offset=$NF+4
        let newNF=$NF+6
        bedtools intersect -wa -wb -loj \
            -a ${input} \
            -b ${HG38_REGIONS} \
            | cut -f1-$NF,$offset-$newNF > ${output}_meres.txt
        input=${output}_meres.txt

        echo "Finding segdup overlap"
        bedtools map \
            -a ${input} \
            -b ${SEGDUPS} \
            -c 4 \
            -o distinct > ${output}_segdups.txt
        input=${output}_segdups.txt
        
        echo "Finding short repeat overlap"
        bedtools map \
            -a ${input} \
            -b ${REPEAT_MASKER} \
            -c 6 \
            -o distinct | awk 'BEGIN{FS=OFS="\t"} {$NF=($NF==-1||$NF==".")?".":"repeat"; print}' > \
            ${output}_repeats.txt
        input=${output}_repeats.txt

        echo "Finding reference gap overlap"
        bedtools map \
            -a ${input} \
            -b ${GAPS} \
            -c 4 \
            -o distinct > ${output}_gaps.txt
        input=${output}_gaps.txt

        echo "Finding homopolymer >= 50bp overlap"
        bedtools map \
            -a ${input} \
            -b ${HOMOPOLYMERS} \
            -c 4 \
            -F 1.0 \
            -o distinct | \
            awk 'BEGIN{FS=OFS="\t"} {$NF=($NF==-1||$NF==".")?".":"HP>=50bp"; print}' \
            > ${output}_homopolymers.txt
        input=${output}_homopolymers.txt

    fi
    if [[ "${SELECTEDANNO}" =~ hiconf ]]
    then
        echo "Finding high confidence region overlap"
        bedtools map \
            -a ${input} \
            -b ${DEFRABB_HICONF} \
            -c 4 \
            -o distinct > ${output}_hiconf.txt
        input=${output}_hiconf.txt
    fi

    cp $input ${output}_posannotations.txt
    echo "Position based annotations complete"
}


printVCF() {
    local vcf=$1
    local input=$2
    local output=$3
    local finalOutput=$4
    local n=$5

    qid=$(basename "$vcf" .vcf.gz)

    echo "Building output VCF"

    paste <( cat $input | awk -v qid=$qid 'BEGIN{OFS="\t"}\
    NR==1{print $1,$2,$4,$5,$6,$7,$3,"Query_ID"}\
    NR>1{print $1,$2,$4,$5,$6,$7,$3,qid}' ) <(cut -f8- $input ) > ${output}_vcf_rearrange.txt

    # infolines built on the input table header
    tableheader=( $(head -n1 ${output}_vcf_rearrange.txt | cut -f 5- ) )
    echo ${tableheader[@]}

    # pull file format and contig list from input vcf for future compatability with different references
    zgrep ^##fileformat $vcf > ${output}.vcf
    zgrep ^##contig= $vcf >> ${output}.vcf

    infolines=()
    for field in ${tableheader[@]}
    do
        echo $field
        infolines+=( ${INFOCOLTEXT[$field]} )
    done

    echo ${infolines[@]} | sed 's/##/\n##/g' | tail -n+2 >> ${output}.vcf

    echo -e '#CHROM\tPOS\tID\tREF\tALT\tQUAL\tFILTER\tINFO' >> ${output}.vcf
    # in a future version should output format tag from original VCF when running just one sample

    infoheaderval=$( echo ${tableheader[@]} | tr ' ' '|' )

    tail -n+2 ${output}_vcf_rearrange.txt | \
        sed 's/;/,/g' | \
        awk -F '\t' \
            -v header=${infoheaderval} \
            'BEGIN{OFS="\t"; ninfo=split(header,infoarray,"|")}
            {
                printf("%s\t%s\t%s\t%s\t%s\t%s\t%s\t",$1,$2,".",$3,$4,".",".")
                for(i=5;i<=NF;i++)
                {
                    printf("%s=%s;", infoarray[i-4], $i)
                }
                printf("\n")
            }' >> ${output}.vcf

    bcftools sort ${output}.vcf -O z -o ${finalOutput}.vcf.gz --write-index=tbi

}

