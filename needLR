validateVCF () {
    local vcf=$1

    inputName="${vcf##*/}"
    inputExt="${inputName##*.}"

    if [[ ! -f $vcf ]]
    then
        echo "${bold}Error: ${normal}$vcf could not be located and may not exist"
        exit 1
    else
        if [[ $inputExt == "vcf" ]]
        then
            #attempt to bgzip and index
            bgzip $vcf
            tabix -p vcf $vcf.gz
            if [ -f "$vcf".gz.tbi ] || [ -f "$vcf.gz.csi" ]
            then
                echo "$vcf".gz
            else
                # quit if it can't be indexed
                echo "${bold}Error: ${normal}$vcf could not be zipped and indexed"
                echo ""
                ${subcommand}Help
                #exit 1
            fi
        elif [[ *"$vcf"* == *"vcf.gz"* ]]
        then
            if [ -f "$vcf".tbi ] || [ -f "$vcf.csi" ]
            then
                echo "$vcf" 
            else
                #if index not found, attempt to index
                tabix -p vcf "$vcf"
                if [ -f "$vcf".tbi ] || [ -f "$vcf.csi" ]
                then
                    echo "$vcf"
                else
                    # quit if it can't be indexed
                    echo "${bold}Error: ${normal}$vcf could not be indexed"
                    echo ""
                    ${subcommand}Help
                    #exit 1
                fi
            fi
        fi
    fi
}

############################# input processing #######################################################################################
#### get subcommand to run

if [ "${#@}" -lt 1 ]
then
    help
    exit 1
fi



subcommand=$1

case ${subcommand} in
    annotate|bed|comparator) ;;
    help|?) help
            exit 0 ;;
    *version) echo "NeedLR version $version"
        exit 0 ;;
    *) echo -e "\nCommand $subcommand not recognized"
        help
        exit 1 ;;
esac

shift

alcannotations=""

### get other flags and options
while getopts HP:C:L:Q:O:B:T:R:-: option
do
    case "${option}" in
        -)
            longoption="${OPTARG}"
            case "${longoption}" in
                omim|gencc|hpo|pli|utr|cds|oreganno|tre|mapflags|hiconf)
                alcannotations+=$alcannotations,$longoption ;;

                all) SELECTEDANNO=$(echo ${ALLANNOTATIONLIST[@]} | tr ' ' ',') ;;
                *) echo "option $longoption not recognized, ignoring" ;;
            esac ;;
        H) help
           exit 0 ;;
        P) PARENTALVCFS="${OPTARG}" ;;
        C) TRUVARI_MERGED_CTRL_SET="${OPTARG}" ;;
        L) QUERY_VCFS="${OPTARG}" ;;
        Q) COHORT_VCF="${OPTARG}" ;;
        O) OUTPUTDIR="${OPTARG}" ;;
        B) refloc="${OPTARG}" ;;
        T) THREADS="${OPTARG}" ;;
        F) FILTERPASS=1 ;;
        R) ANALYSISREGION="${OPTARG}" ;;
        
    esac
done

if [ ${#alcannotations} -gt 0 ]
then
    SELECTEDANNO=${alcannotations}
else
    SELECTEDANNO=$(echo ${ALLANNOTATIONLIST[@]} | tr ' ' ',')
fi

### get positional parameters

shift "$(($OPTIND -1))"

INPUTS=( "$@" )


#### process options and parameters

## check that input exists either as positional parameter, a list, or a vcf or a bed. don't fail the bed yet

# check positional first. if supplied this way, other options are ignored
INPUT_BEDS=()
INPUT_VCFS=()
numInputs="${#INPUTS[@]}"
echo ""
if [[ $numInputs -gt 0 ]]
then
    echo "found ${numInputs} positional arguments, ignoring input from -Q and -L"

    filetypes=()

    for vcf in ${INPUTS[@]}
    do
        inputName=${vcf##*/}
        inputExt=${inputName#*.}
        if [[ $inputExt == "bed" ]]
        then
            INPUT_BEDS+=( "$vcf" )
        elif [[ *"$inputExt"* == *"vcf"* ]]
        then
            INPUT_VCFS+=( $(validateVCF $vcf) )
        fi
    done
elif [[ -z "${QUERY_VCFS+x}" ]]
then
    if [[ -z "${COHORT_VCF+x}" ]]
    then
        echo "${bold}Error: ${normal}no input from -Q, -L, or positional parameters found"
        echo ""
        ${subcommand}Help
        exit 1
    else
    #this block validates the cohort vcf
    # it checks that it exists and ends in vcf.gz and has an index
        if [[ ! -f ${COHORT_VCF} ]]
        then
            echo "${bold}Error: ${normal}File ${COHORT_VCF} could not be found"
            echo ""
            ${subcommand}Help
            exit 1
        fi
        if [[ ! "${COHORT_VCF}" =~ "vcf.gz" ]]
        then
            echo "${bold}Error: ${normal}File ${COHORT_VCF} does not appear to be bgzipped"
            echo ""
            ${subcommand}Help
            exit 1
        fi
        if [[ ! -f "${COHORT_VCF}.tbi" ]] && [[ ! -f "${COHORT_VCF}.csi" ]]
        then
            echo "${bold}Error: ${normal}File ${COHORT_VCF} index not located"
            echo ""
            ${subcommand}Help
            exit 1
        fi
        # cohort_vcf is valid - assign it to the input list.
        INPUT_VCFS=( ${COHORT_VCF} )
    fi
else
    # this block validates the list of file input provided to query_vcfs
    # checks that it exists.
    if [[ ! -f ${QUERY_VCFS} ]]
    then
        echo "${bold}Error: ${normal}File ${QUERY_VCFS} could not be found"
        echo ""
        ${subcommand}Help
        exit 1
    fi
    QUERY_VCF_LIST=( $(cat ${QUERY_VCFS} ) )
    # check that the file is not empty
    if [[ ${#QUERY_VCF_LIST[@]} -lt 1 ]]
    then
        echo "${bold}Error: ${normal} ${QUERY_VCFS} is an empty file"
        echo ""
        ${subcommand}Help
        exit 1
    fi
    # query vcf is valid, iterate over it and check file type, adding valid vcf.gz and vcfs to a list
    for vcf in ${QUERY_VCF_LIST[@]}
    do
        inputName=${vcf##*/}
        inputExt=${inputName#*.}
        if [[ $inputExt == "bed" ]]
        then
            INPUT_BEDS+=( "$vcf" )
        elif [[ *"$inputExt"* == *"vcf"* ]]
        then
